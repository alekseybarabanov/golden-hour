{
  "name": "golden-hour-morning-plan",
  "schedule": {
    "kind": "cron",
    "expr": "0 7 * * *",
    "tz": "Europe/Moscow"
  },
  "sessionTarget": "isolated",
  "payload": {
    "kind": "command",
    "argv": ["sh", "-lc", "node scripts/morning-plan.mjs"],
    "cwd": "~/.openclaw/workspaces/golden-hour"
  },
  "delivery": {
    "mode": "none"
  }
}
