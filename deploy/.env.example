# ================================================================
# Golden Hour — Server Environment Variables
# Copy this to /opt/golden-hour/.env and fill in real values.
# NEVER commit .env with real secrets.
# ================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Google Calendar (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Ports (non-standard by default) ---
# SSH port on your server (configure in sshd_config, not here)
# SSH_PORT=47822  (set as GitHub Actions secret, not in .env)

# Internal application / health-check port
APP_PORT=47832

# Telegram webhook port (only if using webhook mode instead of long-poll)
# Must be one of: 443, 80, 88, 8443 — OR use a reverse proxy
WEBHOOK_PORT=47843

# --- OpenClaw ---
# Path to OpenClaw config (default: ~/.openclaw)
OPENCLAW_CONFIG_DIR=/opt/golden-hour/.openclaw

# --- Node ---
NODE_ENV=production
TZ=Europe/Moscow
