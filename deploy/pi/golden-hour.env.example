# Golden Hour — environment for systemd user timers (Raspberry Pi / Linux).
# Copy to golden-hour.env (same dir). Loaded by every timer service.
# This file holds SECRETS — do not commit golden-hour.env.

# Telegram delivery for cron jobs (morning brief, pings, checkin, timer tick).
# Same token as the bot. Alternatively store it in ~/.openclaw/secrets.json
# (channels.telegram.golden-hour.botToken) and leave this empty.
TELEGRAM_BOT_TOKEN=

# Timezone for calendar-day math (GH_TZ) — IANA name. Set the SAME value with
# `sudo timedatectl set-timezone <Area/City>` so slot times and timer firing agree.
GH_TZ=Europe/Moscow
# Optional: force a fixed UTC offset instead of deriving from GH_TZ.
# GH_TZ_OFFSET=+03:00

# Optional: LAN IP/host of this Pi for the student portal link (portal_url).
# If unset, it is auto-detected from the active network interface.
# GH_STUDENT_PORTAL_HOST=192.168.1.50
